# VitalDB raw dataset — NOT redistributed here.
# Re-fetch on the cluster with slurm/download_vitalfiles.sh (see notes/CLUSTER.md).
# raw dataset + caches live under datasets/<name>/ (fetched/rebuilt, never committed)
datasets/*/data/vital_files/
*.vital
datasets/*/data/clinical_data.csv
datasets/*/cache/
datasets/*/cache_pressor/
lab_data.csv
SHA256SUMS.txt

# Copyrighted papers / large reference material (do not publish)
*.pdf
getting_started.ipynb

# Caches & generated outputs — rebuilt on the cluster / by the scripts
# (outputs/ = loader caches, figures, run logs — all regenerable)
outputs/
*.npz
# gated HF weights (fetched per-machine)
.hf_cache/
# compiled sLSTM kernels
.torch_ext/
logs/

# Bulk analysis outputs — regenerated by the runs (keep only curated inputs in results/)
results/ablation_windows_*.csv
results/ablation_primary_*.json
results/hypo_metrics_*.json
results/clinical_eval_*.json
results/subgroup_forest_*.json
# Derived / cluster-produced artifacts — NEVER track (regenerated by scripts/rebuild_local.sh;
# tracking them causes cluster<->local merge conflicts and stale-clobber on sync).
results/matched_comparison_*.json
results/baseline_meta_*.json
results/baseline_history_*.json
results/baseline_ckpt_*.pt

# Python env / OS cruft
.venv/
venv/
__pycache__/
*.pyc
.DS_Store
.ipynb_checkpoints/

# LaTeX build leftovers
*.aux
*.out
*.toc
*.bbl
*.blg

# stray nested dir + root scratch figures (canonical figs live in manuscript/figs/)
/tirex-2/
/_*.png
/Fig*.png

# figure-editing source + build/local (not shared)
manuscript/figs.pptx
manuscript/*.log
manuscript/*.aux
manuscript/*.out
manuscript/*.bbl
manuscript/*.blg
.claude/

# Zenodo bundle artifacts (uploaded to Zenodo, not tracked in git)
*.tar.gz
BUNDLE_SHA256SUMS.txt

# Internal-only working docs (kept locally, not shared with reviewers)
/RESULTS.md
/results_bundle.tex
/results_bundle.pdf
/notes/RESUME_HERE.md
/notes/PROJECT_PLAN.md
/notes/PAPER_TARGET.md
/notes/RELATED_WORK.md
/notes/API_NOTES.md
/notes/HPC_PORTING.md
/results/comparison_foils*.md

# Intermediate analysis dumps (superseded by curated suppl_*.csv / tables, delivered via Zenodo)
results/_expl_*
results/_rev_*
manuscript/tables.tex
